    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "resend": "^6.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
