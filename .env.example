# ─────────────────────────────────────────────
# AORTHAR ACADEMY — ENVIRONMENT VARIABLES TEMPLATE
# Copy to .env.local and fill in your values
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Paystack ──────────────────────────────────
# Get these from: https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# ── Auth ──────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                     # generate: openssl rand -base64 32

# ── Cron ──────────────────────────────────────
CRON_SECRET=                         # generate: openssl rand -base64 32

# ── Email (Resend — purchase confirmation emails) ─────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# ── AI (optional — powers lesson summary/deep-dive features) ──────────
GEMINI_API_KEY=

# ── App ───────────────────────────────────────
# Controls: admin guard enforcement, demo toggle visibility, env badge in navbar
NEXT_PUBLIC_APP_ENV=development      # development | staging | production
